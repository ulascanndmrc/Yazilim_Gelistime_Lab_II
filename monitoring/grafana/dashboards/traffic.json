{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Microservices Dispatcher Traffic Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(dispatcher_requests_total[1m])",
          "legendFormat": "{{service}} - {{status_code}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(dispatcher_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 - {{service}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(dispatcher_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 - {{service}}",
          "refId": "B"
        }
      ],
      "title": "Response Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [
        {
          "expr": "rate(dispatcher_requests_total{status_code=~'5..'}[5m]) / rate(dispatcher_requests_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by(service) (increase(dispatcher_requests_total[1h]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Requests per Service (1h)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(dispatcher_requests_total{status_code=~'2..'}[5m]))",
          "legendFormat": "2xx Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(dispatcher_requests_total{status_code=~'4..'}[5m]))",
          "legendFormat": "4xx Client Errors",
          "refId": "B"
        },
        {
          "expr": "sum(rate(dispatcher_requests_total{status_code=~'5..'}[5m]))",
          "legendFormat": "5xx Server Errors",
          "refId": "C"
        }
      ],
      "title": "HTTP Status Distribution",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["microservices", "dispatcher"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Dispatcher — Traffic Dashboard",
  "uid": "dispatcher-traffic",
  "version": 1
}
